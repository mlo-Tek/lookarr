# LookArr configuration
# Copy this file to config.yaml and fill in your values.

# --- Required ---

# Your Plex server URL (from Plex Web → Settings → Server ID)
plex_server_url: "https://app.plex.tv/desktop#!/server/YOUR_SERVER_ID"

# Random token of your choice – becomes part of the webhook URL:
# http://UNRAID-IP:32500/YOUR_TOKEN
plex_webhook_token: "some-random-token"

# Discord webhook URL(s) – list for multiple
discord_webhook_urls:
  - "https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN"


# --- Optional ---

# Your personal Plex token (currently only used for Plex deep links)
plex_token: ""

# Only announce these libraries (empty = all)
allowed_libraries: []
  # - "Movies"
  # - "TV Shows"


# --- Security (recommended if exposed to the internet) ---

# IP whitelist – only requests from these IPs/networks are accepted.
# Empty = no whitelist (all IPs allowed).
# Example: only your Plex server (LAN) and Tailscale network:
allowed_ips: []
  # - "192.168.1.50"        # Plex server LAN IP
  # - "192.168.1.0/24"      # entire LAN
  # - "100.64.0.0/10"       # Tailscale network

# Rate limit: max requests per window per IP (default 60 per 60s)
rate_limit_max: 60
rate_limit_window: 60

# Reject requests whose User-Agent does not look like Plex (default true)
require_plex_user_agent: true

# --- Testing ---

# Send a test message to all Discord webhooks once at container start.
# Useful to verify the configuration. Set back to false after a successful test.
send_test_message: false
